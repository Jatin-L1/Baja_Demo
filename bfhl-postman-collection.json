                  "pm.test('official_email present', () => pm.expect(j.official_email).to.be.a('string'));",
                  "pm.test('data is correct fibonacci sequence', () => {",
                  "  pm.expect(j.data).to.deep.equal([0,1,1,2,3,5,8]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
